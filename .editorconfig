# EditorConfig — RMMS 2026
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# ===== Web (TS / TSX / JS / JSON / YAML / MD) =====
[*.{ts,tsx,js,jsx,json,jsonc,yml,yaml,md,mdx,css,scss,html}]
indent_size = 2

# ===== .NET / C# =====
[*.{cs,csx,vb}]
indent_size = 4
# charset inherited from [*] above (utf-8 without BOM).
# We deliberately do NOT require utf-8-bom because:
#   - Files written on Windows + Linux + macOS interleave; BOM is brittle.
#   - dotnet build / Roslyn handle utf-8 (no BOM) correctly since .NET 5+.
#   - `dotnet format --verify-no-changes` flags missing BOM as CHARSET error,
#     which blocked CI without buying any real correctness.
# Code style — see 08-coding-standards.md
csharp_style_namespace_declarations = file_scoped:warning
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_elsewhere = true:suggestion
csharp_new_line_before_open_brace = all
dotnet_diagnostic.IDE0005.severity = warning   # remove unused usings
dotnet_diagnostic.CS8600.severity = warning    # nullable
dotnet_diagnostic.CS8602.severity = warning
dotnet_diagnostic.CS8625.severity = warning

[*.{csproj,props,targets,xml,config}]
indent_size = 2

# ===== Flutter / Dart =====
[*.dart]
indent_size = 2
max_line_length = 100

# ===== Shell / Docker =====
[*.{sh,bash,zsh}]
indent_size = 2

[{Dockerfile,Dockerfile.*,*.dockerfile}]
indent_size = 2

[*.{toml,ini}]
indent_size = 2

[Makefile]
indent_style = tab
