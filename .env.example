# ============================================================
# RMMS 2026 — .env.example
# Copy to `.env` and override locally. NEVER commit real secrets.
# ============================================================

# ---------- PostgreSQL ----------
POSTGRES_DB=rmms
POSTGRES_USER=rmms
POSTGRES_PASSWORD=rmms_dev_pw
# Host port published by docker-compose.prod.yml for external DB clients
POSTGRES_PORT=5432

# ---------- MinIO ----------
MINIO_ROOT_USER=rmms
MINIO_ROOT_PASSWORD=rmms_dev_pw
# Browser-reachable host for presigned image URLs (web admin). Set to your host/domain in prod.
MINIO_PUBLIC_ENDPOINT=localhost:9000

# ---------- Host data directories (bind mounts for easy backup) ----------
# Defaults live under ./data (git-ignored). Override to point at a backup disk if needed.
POSTGRES_DATA_DIR=./data/postgres
MINIO_DATA_DIR=./data/minio
# CompreFace's Postgres data dir (consumed by infra/compreface/docker-compose.yml).
COMPREFACE_DATA_DIR=./data/compreface-pgdata

# ---------- ASP.NET / JWT ----------
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development
# At least 32 bytes — generate with: openssl rand -base64 48
JWT_SIGNING_KEY=replace_me_with_32+_bytes_strong_random_secret_value
JWT_ISSUER=rmms.local
JWT_AUDIENCE=rmms.clients

# ---------- Face Recognition: self-hosted CompreFace (ADR-011, replaces FPT.AI) ----------
# CompreFace runs from infra/compreface/docker-compose.yml (profile: face).
# After it starts, create an Application + "Recognition" service in the CompreFace UI
# (http://<host>:8000) and paste that service's API key below. Blank key => app uses the
# deterministic dev face client (no service needed for local/CI).
CompreFace__BaseUrl=http://compreface-fe:8080
CompreFace__ApiKey=
CompreFace__ConfidenceThreshold=0.85
# CompreFace's own Postgres password (consumed by infra/compreface/docker-compose.yml)
COMPREFACE_POSTGRES_PASSWORD=compreface_dev_pw

# ---------- External integrations (fill in real keys later) ----------
SENDGRID_API_KEY=
FIREBASE_CREDENTIALS_PATH=secrets/firebase-service-account.json

# ---------- Sentry (optional, leave blank to disable) ----------
SENTRY_DSN=

# ---------- Production deploy (docker-compose.prod.yml) ----------
# GHCR namespace holding rmms-api / rmms-worker / rmms-web images
REGISTRY=ghcr.io/nampt102
# Image tag to deploy: "latest" or a released version like "v1.2.0" (pin for rollback)
IMAGE_TAG=latest
# Host port Caddy publishes (host 80/443 are taken by another app). App is reached
# at http://<server-ip>:<HTTP_PORT> ; Caddy path-routes /api → api, rest → web.
HTTP_PORT=5010
# Public origin users open in the browser — MUST match HTTP_PORT above.
# Used for approval-email links (BR-407) + CORS. No trailing slash.
# IMPORTANT: build the rmms-web image with NEXT_PUBLIC_API_BASE_URL EMPTY so the
# browser calls relative /api/* (same origin) — do NOT bake an IP here.
PUBLIC_BASE_URL=http://103.216.116.206:5010
# MinIO presigned URLs use direct ip:9000 (port published on the minio service).
MINIO_PUBLIC_USE_SSL=false

# ---------- Production secrets (docker-compose.prod.yml — api/worker) ----------
# HMAC secret for BUH email-link approval tokens (BR-407) — openssl rand -base64 48
APPROVAL_SIGNING_KEY=replace_me_with_strong_random_secret
# Email provider: Smtp | SendGrid | Console (Console = log only, no real email)
EMAIL_PROVIDER=Smtp
EMAIL_FROM_EMAIL=noreply@rmms.local
EMAIL_FROM_NAME=RMMS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Push: fcm (requires ./secrets/firebase-service-account.json on the server) | console
PUSH_PROVIDER=fcm
# Swagger UI at /swagger on the prod stack (true while testing; set false to hide)
SWAGGER_ENABLED=true
