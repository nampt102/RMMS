# ==============================
# RMMS 2026 — .gitignore (root)
# ==============================

# OS
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# MS Office lock / temp files (created when a doc is open in Excel/Word/PowerPoint)
~$*.xlsx
~$*.xlsm
~$*.xls
~$*.docx
~$*.doc
~$*.pptx
~$*.ppt

# IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env files (NEVER commit)
.env
.env.local
.env.*.local
*.env
!.env.example
!.env.*.example

# Secrets
secrets/
*.pem
*.key
*.pfx
*.p12

# Docker volumes
docker-data/
postgres-data/
redis-data/
minio-data/
caddy-data/

# ============ .NET ============
backend/**/bin/
backend/**/obj/
backend/**/out/
backend/**/publish/
backend/**/*.user
backend/**/*.suo
backend/TestResults/
backend/coverage/
backend/**/*.lock.json
backend/.idea/

# ============ Node / Next.js ============
web/node_modules/
web/.next/
web/out/
web/build/
web/.turbo/
web/coverage/
web/.swc/
web/next-env.d.ts
web/.vercel/

# Flutter
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/.pub-cache/
mobile/.pub/
mobile/build/
mobile/.idea/
mobile/.gradle/
mobile/android/.gradle/
mobile/android/local.properties
mobile/android/app/debug/
mobile/android/app/profile/
mobile/android/app/release/
mobile/ios/Pods/
mobile/ios/.symlinks/
mobile/ios/Flutter/Flutter.framework
mobile/ios/Flutter/Flutter.podspec
mobile/ios/Flutter/flutter_export_environment.sh
mobile/ios/Flutter/Generated.xcconfig
mobile/ios/Flutter/ephemeral/
mobile/**/*.g.dart
mobile/**/*.freezed.dart
mobile/**/*.gr.dart
mobile/**/*.config.dart
mobile/coverage/

# ============ Misc ============
*.bak
*.tmp
tmp/
temp/
