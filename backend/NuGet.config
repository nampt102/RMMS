<?xml version="1.0" encoding="utf-8"?>
<!--
  Local NuGet config for RMMS backend.

  Why this file exists:
    The dev machine may have additional NuGet sources configured at user/machine level
    (e.g., DevExpress, internal feeds). Central Package Management (CPM) requires either
    a single source or explicit `<packageSourceMapping>` to avoid ambiguity (NU1507).

  What it does:
    - <clear /> removes any inherited sources for projects under this folder
    - Adds only nuget.org so all RMMS packages come from a single, public, audited source
    - Does NOT affect other projects on the same machine — scope is this folder + subfolders

  If you need to pull from an internal feed for some packages later, switch to
  packageSourceMapping (see https://aka.ms/nuget-package-source-mapping).
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>

  <config>
    <add key="dependencyVersion" value="Highest" />
  </config>
</configuration>
