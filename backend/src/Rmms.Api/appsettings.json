{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/rmms-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Port=5432;Database=rmms;Username=rmms;Password=rmms_dev_pw;Include Error Detail=true",
    "Redis": "redis:6379,abortConnect=false"
  },
  "Jwt": {
    "Issuer": "rmms.local",
    "Audience": "rmms.clients",
    "SigningKey": "REPLACE_WITH_AT_LEAST_32_BYTES_STRONG_RANDOM_SECRET",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000"
    ]
  },
  "FptAi": {
    "BaseUrl": "https://api.fpt.ai/dmp/checkface/v1/",
    "ApiKey": "REPLACE_ME"
  },
  "SendGrid": {
    "ApiKey": "REPLACE_ME",
    "FromEmail": "noreply@motivesvn.com",
    "FromName": "RMMS"
  },
  "Firebase": {
    "CredentialsJsonPath": "secrets/firebase-service-account.json"
  },
  "MinIO": {
    "Endpoint": "minio:9000",
    "AccessKey": "rmms",
    "SecretKey": "rmms_dev_pw",
    "BucketName": "rmms",
    "UseSsl": false
  }
}
